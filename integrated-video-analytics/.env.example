# Core optional cloud integration keys
PLATE_RECOGNIZER_API_TOKEN=
GEMINI_API_KEY=

# Gemini enrichment
CYBERSHIELD_ENABLE_GEMINI_ENRICHMENT=false
CYBERSHIELD_GEMINI_MODEL=gemini-2.0-flash

# Detection accuracy upgrades
# Advanced detector defaults
CYBERSHIELD_ENABLE_ADVANCED_ON_GPU=true
CYBERSHIELD_ENABLE_HEAVY_VALIDATOR=true
CYBERSHIELD_HEAVY_VALIDATOR_MODEL=yolov8x.pt
CYBERSHIELD_HEAVY_VALIDATOR_MIN_CONF=0.15
CYBERSHIELD_HEAVY_VALIDATOR_MAX_CONF=0.45
CYBERSHIELD_HEAVY_VALIDATOR_IOU=0.45
CYBERSHIELD_HEAVY_VALIDATOR_INTERVAL=2

# SAHI sliced inference (small-object recall)
CYBERSHIELD_ENABLE_SAHI_INFERENCE=true
CYBERSHIELD_SAHI_SLICE_HEIGHT=512
CYBERSHIELD_SAHI_SLICE_WIDTH=512
CYBERSHIELD_SAHI_OVERLAP_HEIGHT=0.2
CYBERSHIELD_SAHI_OVERLAP_WIDTH=0.2
CYBERSHIELD_SAHI_TRIGGER_MIN_WIDTH=1600
CYBERSHIELD_SAHI_INTERVAL=4

# RT-DETR confirmation
CYBERSHIELD_ENABLE_RTDETR_CONFIRMATION=true
CYBERSHIELD_RTDETR_MODEL=rtdetr-l.pt
CYBERSHIELD_RTDETR_MIN_CONF=0.15
CYBERSHIELD_RTDETR_IOU=0.45
CYBERSHIELD_RTDETR_INTERVAL=3

# Adaptive governor (protects smooth feed under load)
CYBERSHIELD_ENABLE_ADAPTIVE_GOVERNOR=true
CYBERSHIELD_ADAPTIVE_TARGET_FPS=18
CYBERSHIELD_ADAPTIVE_MAX_INFER_MS=85
CYBERSHIELD_ADAPTIVE_HYSTERESIS_FRAMES=5

# API auth
ADMIN_API_TOKEN=

# Websocket push interval (seconds)
CYBERSHIELD_WS_INTERVAL=1.0
